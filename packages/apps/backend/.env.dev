DEBUG_MODE=true
SINGLE_TENANT_MODE=true

# POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__DATABASE=rezible
POSTGRES__SSLMODE=disable

POSTGRES__ROLE_ADMIN__NAME=postgres
POSTGRES__ROLE_ADMIN__PASSWORD=password

POSTGRES__ROLE_APP__NAME=rez_app
POSTGRES__ROLE_APP__PASSWORD=rez_app

SERVER__HTTP__PORT=7001
SERVER__HTTP__DOCUMENTS_PROXY__ENABLED=true
SERVER__HTTP__DOCUMENTS_PROXY__PROXY_PATH=/documents
# SERVER__HTTP__DOCUMENTS_PROXY__PROXY_HOST=http://localhost:7002

# AUTH__OIDC__ISSUER=${AUTH_URL}
AUTH__OIDC__CLIENT_ID=test-client
AUTH__OIDC__CLIENT_SECRET=superdupersecret
AUTH__SESSION_SECRET=superduuuuuuuuuuuuuuuuupersecret
