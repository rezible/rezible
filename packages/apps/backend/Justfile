set shell := ["bash", "-uc"]

export APP__DEBUG_MODE := "true"
export APP__FRONTEND_URL := env("APP_URL")
export APP__API_URL := env("API_URL")
export APP__SINGLETENANT__ENABLED := "true"

export HTTP__PORT := env("BACKEND_PORT")
export HTTP__AUTH__SESSION_SECRET := "superduuuuuuuuuuuuuuuuupersecret"
export HTTP__AUTH__OIDC__ISSUER := env("AUTH_URL")
export HTTP__AUTH__OIDC__CLIENT_ID := "test-client"
export HTTP__AUTH__OIDC__CLIENT_SECRET := "superdupersecret"
export HTTP__DOCUMENTS_PROXY__ENABLED := "true"
export HTTP__DOCUMENTS_PROXY__PROXY_PATH := "/documents"

export POSTGRES__HOST := "localhost"
export POSTGRES__PORT := env("POSTGRES_PORT")
export POSTGRES__DATABASE := env("POSTGRES_APP_DB", "rezible-main")
export POSTGRES__SSLMODE := "disable"
export POSTGRES__ROLE_ADMIN__NAME := env("POSTGRES_ADMIN_USER", "postgres")
export POSTGRES__ROLE_ADMIN__PASSWORD := POSTGRES__ROLE_ADMIN__NAME
export POSTGRES__ROLE_APP__NAME := env("POSTGRES_APP_USER")
export POSTGRES__ROLE_APP__PASSWORD := POSTGRES__ROLE_APP__NAME

export OTEL_SERVICE_NAME := "rezible-backend"
export OTEL_TRACES_EXPORTER := "otlp"
export OTEL_METRICS_EXPORTER := "otlp"
export OTEL_LOGS_EXPORTER := "none"
export OTEL_EXPORTER_OTLP_ENDPOINT := "http://localhost:" + env("OTEL_GRPC_PORT", "4317")
export OTEL_EXPORTER_OTLP_PROTOCOL := "grpc"

_default:
  @just --list

install:
    go mod tidy

format:
    go fmt ./...

@dev:
    go tool reflex -r '\.go' -s -- sh -c 'go run ./cmd/rezible serve'

@run *ARGS:
    go run ./cmd/rezible {{ARGS}}

@test *ARGS:
    go test {{ARGS}}

exclude_test_packages_pattern := "/ent/"

@test-all:
    just test $(go list ./... | grep -v '{{exclude_test_packages_pattern}}')

@test-package PACKAGE *ARGS:
    just test '{{PACKAGE}}' {{ARGS}}

@test-pattern PATTERN:
    just test $(go list ./... | grep -v '{{exclude_test_packages_pattern}}') -run {{PATTERN}}

@codegen:
    go generate ./...

@gen-api:
    go generate ./openapi

@gen-schema:
    go generate ./ent

@gen-mocks:
    go generate ./testkit/mocks

@gen-migration NAME:
    just run migrations create '{{NAME}}'

@apply-migrations:
    just run migrations apply

[working-directory(".")]
@create-initial-migration:
    rm -f ./internal/postgres/migrations/0001_init*.sql
    rm -f ./internal/postgres/migrations/atlas.sum
    just run migrations update-checksum
    just run migrations create init
    just run migrations update-checksum
