set shell := ["bash", "-uc"]
set fallback

install:
    go mod tidy

format:
    go fmt ./...

@dev:
    go tool air -c .air.toml

@run *ARGS:
    go run ./cmd/rezible {{ARGS}}

@test:
    just start-db
    go test $(go list ./... | grep -v /ent/)

@gen:
    go generate ./...

@gen-api:
    go generate ./openapi

@gen-schema:
    go generate ./ent

@gen-mocks:
    go generate ./testkit/mocks

@gen-migration NAME:
    just run migrations create '{{NAME}}'

@apply-migrations:
    just run migrations apply

[working-directory("./internal/postgres/migrations")]
@create-initial-migrations:
    rm -f ./migrations/0001_init*.sql
    rm -f ./migrations/atlas.sum
    just run migrations update-checksum
    just run migrations create init
    just run migrations update-checksum
