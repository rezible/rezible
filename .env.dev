DEV_DOMAIN=dev.rezible.com
APP_AUTH_CLIENT_CALLBACK_PATH=/auth/callback
API_HOST=api.${DEV_DOMAIN}
API_URL=https://${API_HOST}
APP_HOST=app.${DEV_DOMAIN}
APP_URL=https://${APP_HOST}

DEX_PATH=/dex
DEX_URL=${APP_URL}${DEX_PATH}
DEX_PORT=7011

REZ_APP_PORT=7000
REZ_BACKEND_PORT=7001
REZ_DOCUMENTS_SERVER_PORT=7002

PROXY_HOST=localhost
POSTGRES_HOST=${POSTGRES_HOST:-localhost}
POSTGRES_PORT=${POSTGRES_PORT:-7010}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable

POSTGRES_ADMIN_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/?sslmode=${POSTGRES_SSLMODE}
POSTGRES_DOCUMENTS_URL=postgresql://${POSTGRES_REZ_DOCUMENTS_USER}:${POSTGRES_REZ_DOCUMENTS_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_REZ_DATABASE}?sslmode=${POSTGRES_SSLMODE}

POSTGRES_DEX_DATABASE=dex
POSTGRES_DEX_USER=dex
POSTGRES_DEX_PASSWORD=dex

POSTGRES_REZ_DATABASE=rezible
POSTGRES_REZ_ADMIN_USER=rez_admin
POSTGRES_REZ_ADMIN_PASSWORD=rez_admin
POSTGRES_REZ_APP_USER=rez_app
POSTGRES_REZ_APP_PASSWORD=rez_app
POSTGRES_REZ_DOCUMENTS_USER=rez_documents
POSTGRES_REZ_DOCUMENTS_PASSWORD=rez_documents

# DB Bootstrap Config
BOOTSTRAP__DEX_PASSWORD=${POSTGRES_DEX_PASSWORD}
BOOTSTRAP__REZ_ADMIN_PASSWORD=${POSTGRES_REZ_ADMIN_PASSWORD}
BOOTSTRAP__REZ_APP_PASSWORD=${POSTGRES_REZ_APP_PASSWORD}
BOOTSTRAP__REZ_DOCUMENTS_PASSWORD=${POSTGRES_REZ_DOCUMENTS_PASSWORD}

APP_OIDC_CLIENT_ID=rezible-app
APP_OIDC_CLIENT_SCOPES="openid profile email"
APP_OIDC_CLIENT_REDIRECT_URI=${APP_URL}${APP_AUTH_CLIENT_CALLBACK_PATH}

# Frontend Config
PROXY_BACKEND_UPSTREAM_HOST=${PROXY_HOST}:${REZ_BACKEND_PORT}
PROXY_DOCUMENTS_SERVER_UPSTREAM_HOST=${PROXY_HOST}:${REZ_DOCUMENTS_SERVER_PORT}
PROXY_DEX_UPSTREAM_HOST=${PROXY_HOST}:${DEX_PORT}

# Backend Config
DEBUG_MODE=true

POSTGRES__HOST=${POSTGRES_HOST:-localhost}
POSTGRES__PORT=${POSTGRES_PORT:-7010}
POSTGRES__DATABASE=${POSTGRES_REZ_DATABASE}
POSTGRES__SSLMODE=${POSTGRES_SSLMODE}
POSTGRES__USER=${POSTGRES_REZ_APP_USER}
POSTGRES__PASSWORD=${POSTGRES_REZ_APP_PASSWORD}
POSTGRES__MIGRATIONS__USER=${POSTGRES_REZ_ADMIN_USER}
POSTGRES__MIGRATIONS__PASSWORD=${POSTGRES_REZ_ADMIN_PASSWORD}

SERVER__HTTP__PORT=${REZ_BACKEND_PORT}
SERVER__HTTP__DOCUMENTS_PROXY__ENABLED=true
SERVER__HTTP__DOCUMENTS_PROXY__PROXY_PATH=/documents
SERVER__HTTP__DOCUMENTS_PROXY__PROXY_HOST=${PROXY_DOCUMENTS_SERVER_UPSTREAM_HOST}

AUTH__OIDC__ISSUER_URL=${DEX_URL}
AUTH__OIDC__CLIENT_ID=${APP_OIDC_CLIENT_ID}
AUTH__OIDC__CLIENT_REDIRECT_URI=${APP_OIDC_CLIENT_REDIRECT_URI}
AUTH__OIDC__CLIENT_SCOPES=${APP_OIDC_CLIENT_SCOPES}
AUTH__ALLOW_ACCESS__PUBLIC_SIGNUP=false
AUTH__ALLOW_ACCESS__DOMAINS="${DEV_DOMAIN}"

# POSTHOG__API_KEY=
# ANTHROPIC__API_KEY=

# SLACK__ENABLED=false
# SLACK__APP_ID=
# SLACK__BOT_TOKEN=
# SLACK__APP_TOKEN=
# SLACK__OAUTH__CLIENT_ID=
# SLACK__OAUTH__CLIENT_SECRET=
# SLACK__WEBHOOKS__SIGNING_SECRET=
# SLACK__SOCKETMODE__ENABLED=false
