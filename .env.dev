DEV_DOMAIN=dev.rezible.com

APP_HOST=app.${DEV_DOMAIN}
APP_URL=https://${APP_HOST}
REZ_APP_PORT=7000

API_HOST=api.${DEV_DOMAIN}
API_URL=https://${API_HOST}
REZ_BACKEND_PORT=7001

AUTH_HOST=accounts.${DEV_DOMAIN}
AUTH_URL=https://${AUTH_HOST}
AUTH_PORT=7011

REZ_DOCUMENTS_SERVER_PORT=7002

PROXY_HOST=localhost

POSTGRES_HOST=localhost
POSTGRES_PORT=7010
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rezible
POSTGRES_SSLMODE=disable

# Frontend Config
PROXY_BACKEND_UPSTREAM_HOST=${PROXY_HOST}:${REZ_BACKEND_PORT}
PROXY_DOCUMENTS_SERVER_UPSTREAM_HOST=${PROXY_HOST}:${REZ_DOCUMENTS_SERVER_PORT}
PROXY_AUTH_UPSTREAM_HOST=${PROXY_HOST}:${AUTH_PORT}

# Backend Config
DEBUG_MODE=true
SINGLE_TENANT_MODE=true

POSTGRES__HOST=${POSTGRES_HOST}
POSTGRES__PORT=${POSTGRES_PORT}
POSTGRES__DATABASE=${POSTGRES_DB}
POSTGRES__SSLMODE=${POSTGRES_SSLMODE}

POSTGRES__ROLE_ADMIN__NAME=${POSTGRES_USER}
POSTGRES__ROLE_ADMIN__PASSWORD=${POSTGRES_PASSWORD}

POSTGRES__ROLE_APP__NAME=rez_app
POSTGRES__ROLE_APP__PASSWORD=rez_app

POSTGRES__ROLE_DOCUMENTS__NAME=rez_documents
POSTGRES__ROLE_DOCUMENTS__PASSWORD=rez_documents

SERVER__HTTP__PORT=${REZ_BACKEND_PORT}
SERVER__HTTP__DOCUMENTS_PROXY__ENABLED=true
SERVER__HTTP__DOCUMENTS_PROXY__PROXY_PATH=/documents
SERVER__HTTP__DOCUMENTS_PROXY__PROXY_HOST=${PROXY_DOCUMENTS_SERVER_UPSTREAM_HOST}

AUTH__OIDC__ISSUER=${AUTH_URL}
AUTH__SESSION_SECRET=superduuuuuuuuuuuuuuuuupersecret
AUTH__OIDC__CLIENT_ID=test-client
AUTH__OIDC__CLIENT_SECRET=superdupersecret

