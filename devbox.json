{
  "$schema": "https://raw.githubusercontent.com/jetpack-io/devbox/0.10.1/.schema/devbox.schema.json",
  "packages": {
    "reflex":                      "latest",
    "bun":                         "latest",
    "just":                        "latest",
    "go":                          "latest",
    "process-compose":             "latest",
    "github:peterldowns/localias": "",
    "go-migrate":                  "4.18.1",
    "go-mockery":                  "latest"
  },
  "shell": {
    "init_hook": ["unset DEVELOPER_DIR"]
  },
  "env": {
    "LOCAL_DEV_HOST": "dev.rezible.com",
    "TEST_OIDC_CLIENT_ID": "client",
    "TEST_OIDC_CLIENT_SECRET": "secret"
  }
}
