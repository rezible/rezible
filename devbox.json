{
  "$schema": "https://raw.githubusercontent.com/jetpack-io/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": {
    "reflex":                      "latest",
    "bun":                         "latest",
    "just":                        "latest",
    "go":                          "latest",
    "process-compose":             "latest",
    "github:peterldowns/localias": "",
    "go-migrate":                  "4.18.1",
    "go-mockery":                  "latest"
  },
  "env": {
    "LOCAL_DEV_HOST": "dev.rezible.com"
  },
  "shell": {
    "init_hook": [
      "unset DEVELOPER_DIR",
      "localias stop && localias start"
    ]
  }
}
