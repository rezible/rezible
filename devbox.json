{
  "$schema": "https://raw.githubusercontent.com/jetpack-io/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": {
    "bun": "latest",
    "just": "latest",
    "go": "latest",
    "process-compose": "latest",
    "github:peterldowns/localias": "",
    "dotenvx": "latest",
    "wget": "latest"
  },
  "env_from": ".env",
  "env": {
    "DEV_DOMAIN": "dev.rezible.com",
    "APP_PORT": "7000",
    "APP_DOMAIN": "app.dev.rezible.com",
    "APP_URL": "https://app.dev.rezible.com",
    "AUTH_PORT": "7011",
    "AUTH_DOMAIN": "auth.dev.rezible.com",
    "AUTH_URL": "https://auth.dev.rezible.com",
    "BACKEND_PORT": "7001",
    "API_DOMAIN": "api.dev.rezible.com",
    "API_URL": "https://api.dev.rezible.com",
    "POSTGRES_PORT": "7010",
    "POSTGRES_ADMIN_USER": "postgres",
    "POSTGRES_APP_USER": "rez_app",
    "GRAFANA_PORT": "7012",
    "DOCUMENTS__SESSION_TOKEN_SECRET_HEX": "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"
  },
  "shell": {
    "init_hook": [
      "unset DEVELOPER_DIR",
      "cp \"$(localias debug cert)\" ./devenv/localias-ca.crt"
    ]
  }
}
